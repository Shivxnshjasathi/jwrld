rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Assets are readable by everyone, writable only by admins
    match /assets/{assetId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Bookings are readable by all authenticated users (to check availability)
    // writable by the owner or admins
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == request.resource.data.userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Food orders are readable/writable by the owner or admins
    match /foodOrders/{orderId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == request.resource.data.userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Users can read/write their own profile; admins can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Events & Tournaments
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Event Registrations
    match /event_registrations/{regId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // Chats and messages for the messaging feature
    match /chats/{userId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Waitlist is readable and writable by authenticated users
    match /waitlist/{waitlistId} {
      allow read, write: if request.auth != null;
    }

    // Settings (announcements etc.) readable by all auth users, writable by admins
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Coupons are readable by all authenticated users, writable by admins
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
